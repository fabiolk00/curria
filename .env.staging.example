# Staging Environment Configuration
# Copy this file to .env.staging and fill in with actual staging values
# IMPORTANT: Do NOT commit .env.staging to git (it contains credentials)

# ============================================================================
# STAGING DATABASE
# ============================================================================
# Isolated PostgreSQL database for staging validation
# Must be completely separate from production

# Supabase staging project example:
# STAGING_DB_URL="postgresql://postgres:password123@db.xxxxxxxxxxxx.supabase.co:5432/postgres"

# Self-hosted PostgreSQL example:
# STAGING_DB_URL="postgresql://postgres:password@localhost:5433/curria_staging"

# Local Docker example:
# STAGING_DB_URL="postgresql://postgres:staging_password@host.docker.internal:5433/curria_staging"

STAGING_DB_URL="postgresql://postgres:REPLACE_WITH_STAGING_PASSWORD@REPLACE_WITH_HOST:5432/REPLACE_WITH_DATABASE"

# ============================================================================
# STAGING API
# ============================================================================
# URL where the staging webhook endpoint is deployed
# Used by validation agent to send test webhooks

# Example: https://staging-curria.example.com
# Example: https://staging.curria.dev
# Example: http://localhost:3000 (for local testing)

STAGING_API_URL="https://REPLACE_WITH_STAGING_DOMAIN/api/webhook/asaas"

# ============================================================================
# ASAAS SANDBOX CREDENTIALS
# ============================================================================
# These MUST be sandbox/test credentials only
# Never use production Asaas credentials in staging

# Asaas Webhook Token (from Asaas sandbox dashboard)
# Found in: Settings > Webhooks > Token
STAGING_ASAAS_WEBHOOK_TOKEN="REPLACE_WITH_ASAAS_SANDBOX_WEBHOOK_TOKEN"

# Asaas API Key (from Asaas sandbox dashboard)
# Found in: Settings > API Keys
# Used to create test payments/subscriptions if needed
STAGING_ASAAS_ACCESS_TOKEN="REPLACE_WITH_ASAAS_SANDBOX_API_TOKEN"

# ============================================================================
# OPTIONAL: STAGING-SPECIFIC SETTINGS
# ============================================================================
# Use these to enable detailed logging in staging for debugging

# Log level for debugging
# STAGING_LOG_LEVEL="debug"

# Enable detailed structured logging
# STAGING_ENABLE_DETAILED_LOGGING="true"

# Slack webhook for staging alerts (optional)
# STAGING_SLACK_WEBHOOK="https://hooks.slack.com/services/..."

# ============================================================================
# USAGE NOTES
# ============================================================================
#
# 1. Before running validation, load this file:
#    export $(cat .env.staging | xargs)
#
# 2. Verify all values are set and non-empty:
#    echo "DB: $STAGING_DB_URL"
#    echo "API: $STAGING_API_URL"
#    echo "Token: ${STAGING_ASAAS_WEBHOOK_TOKEN:0:10}..."
#
# 3. Test database connectivity:
#    psql "$STAGING_DB_URL" -c "SELECT 1;"
#
# 4. Verify migration is applied:
#    psql "$STAGING_DB_URL" -c "SELECT COUNT(*) FROM billing_checkouts;"
#
# 5. Run verification script:
#    ./scripts/verify-staging.sh
#
# 6. Execute validation agent:
#    npm run agent:validate-billing
#
# ============================================================================
