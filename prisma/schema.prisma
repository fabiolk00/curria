generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CVVersionSource {
  ingestion
  rewrite
  manual
  targetDerived @map("target-derived")

  @@map("cv_version_source")
}

enum JobApplicationStatus {
  entrevista
  aguardando
  sem_retorno
  negativa

  @@map("job_application_status")
}

enum ResumeGenerationType {
  ATS_ENHANCEMENT
  JOB_TARGETING

  @@map("resume_generation_type")
}

model Session {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  stateVersion   Int       @default(1) @map("state_version")
  phase          String    @default("intake")
  cvState        Json      @map("cv_state")
  agentState     Json      @default("{}") @map("agent_state")
  generatedOutput Json     @default("{}") @map("generated_output")
  atsScore       Json?     @map("ats_score")
  creditsUsed    Int       @default(0) @map("credits_used")
  messageCount   Int       @default(0) @map("message_count")
  creditConsumed Boolean   @default(false) @map("credit_consumed")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  messages       Message[]
  cvVersions     CVVersion[]
  resumeTargets  ResumeTarget[]
  resumeGenerations ResumeGeneration[]

  @@index([userId])
  @@map("sessions")
}

model CVVersion {
  id             String       @id @default(cuid())
  sessionId      String       @map("session_id")
  targetResumeId String?      @map("target_resume_id")
  snapshot       Json
  source         CVVersionSource
  createdAt      DateTime     @default(now()) @map("created_at")

  session        Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  targetResume   ResumeTarget? @relation(fields: [targetResumeId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([targetResumeId])
  @@map("cv_versions")
}

model ResumeTarget {
  id                   String      @id @default(cuid())
  sessionId            String      @map("session_id")
  targetJobDescription String      @map("target_job_description")
  derivedCvState       Json        @map("derived_cv_state")
  gapAnalysis          Json?       @map("gap_analysis")
  generatedOutput      Json?       @map("generated_output")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  session              Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  cvVersions           CVVersion[]
  resumeGenerations    ResumeGeneration[]

  @@index([sessionId, createdAt])
  @@map("resume_targets")
}

model JobApplication {
  id                 String               @id @default(cuid())
  userId             String               @map("user_id")
  role               String
  company            String
  status             JobApplicationStatus @default(aguardando)
  salary             String?
  location           String?
  benefits           Json                 @default("[]")
  resumeVersionLabel String               @map("resume_version_label")
  jobDescription     String?              @map("job_description")
  notes              String?
  appliedAt          DateTime             @default(now()) @map("applied_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, appliedAt])
  @@index([userId, status, appliedAt])
  @@map("job_applications")
}

model Message {
  id         String   @id @default(cuid())
  sessionId  String   @map("session_id")
  role       String   // "user" | "assistant"
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("messages")
}

model UserQuota {
  id                  String    @id @default(cuid())
  userId              String    @unique @map("user_id")
  plan                String    @default("free")  // Metadata only: "free" | "monthly" | "pro"
  creditsRemaining    Int       @default(0) @map("credits_remaining") // Legacy compatibility only; runtime credits live in credit_accounts
  asaasCustomerId     String?   @map("asaas_customer_id")
  asaasSubscriptionId String?   @map("asaas_subscription_id")
  renewsAt            DateTime? @map("renews_at")
  status              String    @default("active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user                User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([asaasCustomerId])
  @@index([asaasSubscriptionId])
  @@map("user_quotas")
}

model BillingCheckout {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  checkoutReference   String   @unique @map("checkout_reference")
  plan                String
  amountMinor         Int      @map("amount_minor")
  currency            String   @default("BRL")
  status              String   @default("pending")
  asaasLink           String?  @map("asaas_link")
  asaasPaymentId      String?  @map("asaas_payment_id")
  asaasSubscriptionId String?  @map("asaas_subscription_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user                User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([userId, status])
  @@index([asaasPaymentId])
  @@index([asaasSubscriptionId])
  @@map("billing_checkouts")
}

model ProcessedEvent {
  id               String   @id @default(cuid())
  eventId          String   @map("event_id")
  eventFingerprint String   @unique @map("event_fingerprint")
  eventType        String   @map("event_type")
  eventPayload     Json?    @map("event_payload")
  processedAt      DateTime @default(now()) @map("processed_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([eventId, eventType])
  @@index([createdAt])
  @@map("processed_events")
}

model ApiUsage {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  sessionId    String?  @map("session_id")
  model        String
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  totalTokens  Int      @map("total_tokens")
  costCents    Int      @map("cost_cents") // Cost in cents (USD) for easy integer math
  endpoint     String   // "agent" | "rewriter" | "ocr"
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([createdAt])
  @@map("api_usage")
}

model User {
  id             String             @id
  status         String             @default("active")
  displayName    String?            @map("display_name")
  primaryEmail   String?            @map("primary_email")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  authIdentities UserAuthIdentity[]
  creditAccount  CreditAccount?
  sessions       Session[]
  quota          UserQuota?
  apiUsage       ApiUsage[]
  billingCheckouts BillingCheckout[]
  jobApplications JobApplication[]
  billingInfo    CustomerBillingInfo?
  profile        UserProfile?
  linkedInImportJobs LinkedInImportJob[]
  resumeGenerations ResumeGeneration[]
  creditConsumptions CreditConsumption[]

  @@map("users")
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  cvState     Json
  source      String   // 'linkedin' | 'pdf'
  linkedinUrl String?  @map("linkedin_url")
  profilePhotoUrl String? @map("profile_photo_url")
  extractedAt DateTime @map("extracted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_profiles")
}

model LinkedInImportJob {
  id           String    @id @default(dbgenerated("gen_random_uuid()::text"))
  userId       String    @map("user_id")
  linkedinUrl  String    @map("linkedin_url")
  status       String    @default("pending") // 'pending' | 'processing' | 'completed' | 'failed'
  errorMessage String?   @map("error_message")
  claimedAt    DateTime? @map("claimed_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("linkedin_import_jobs")
}

model UserAuthIdentity {
  id              String    @id
  userId          String    @map("user_id")
  provider        String
  providerSubject String    @map("provider_subject")
  email           String?
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("user_auth_identities")
}

model CreditAccount {
  id               String   @id
  userId           String   @unique @map("user_id")
  creditsRemaining Int      @default(0) @map("credits_remaining") // Authoritative credit balance for all runtime checks and mutations
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_accounts")
}

model CustomerBillingInfo {
  id            String    @id @default(cuid())
  userId        String    @unique @map("user_id")
  cpfCnpj       String    @map("cpf_cnpj")
  phoneNumber   String    @map("phone_number")
  address       String
  addressNumber String    @map("address_number")
  postalCode    String    @map("postal_code")
  province      String
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("customer_billing_info")
}

model ResumeGeneration {
  id               String               @id @default(cuid())
  userId           String               @map("user_id")
  sessionId        String?              @map("session_id")
  resumeTargetId   String?              @map("resume_target_id")
  type             ResumeGenerationType
  status           String               @default("pending")
  idempotencyKey   String?              @unique @map("idempotency_key")
  sourceCvSnapshot Json                 @map("source_cv_snapshot")
  generatedCvState Json?                @map("generated_cv_state")
  outputPdfPath    String?              @map("output_pdf_path")
  outputDocxPath   String?              @map("output_docx_path")
  failureReason    String?              @map("failure_reason")
  versionNumber    Int                  @default(1) @map("version_number")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  session          Session?             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  resumeTarget     ResumeTarget?        @relation(fields: [resumeTargetId], references: [id], onDelete: SetNull)
  creditConsumptions CreditConsumption[]

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([resumeTargetId, createdAt])
  @@map("resume_generations")
}

model CreditConsumption {
  id                 String               @id @default(cuid())
  userId             String               @map("user_id")
  resumeGenerationId String               @unique @map("resume_generation_id")
  type               ResumeGenerationType
  creditsUsed        Int                  @default(1) @map("credits_used")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeGeneration   ResumeGeneration     @relation(fields: [resumeGenerationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_consumptions")
}
