generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CVVersionSource {
  ingestion
  rewrite
  manual
  atsEnhancement @map("ats-enhancement")
  targetDerived @map("target-derived")

  @@map("cv_version_source")
}

enum JobApplicationStatus {
  entrevista
  aguardando
  sem_retorno
  negativa

  @@map("job_application_status")
}

enum ResumeGenerationType {
  ATS_ENHANCEMENT
  JOB_TARGETING

  @@map("resume_generation_type")
}

enum CreditReservationStatus {
  reserved
  finalized
  released
  needs_reconciliation

  @@map("credit_reservation_status")
}

enum CreditReservationReconciliationStatus {
  clean
  pending
  repaired
  manual_review

  @@map("credit_reservation_reconciliation_status")
}

enum CreditLedgerEntryType {
  reservation_hold
  reservation_finalize
  reservation_release

  @@map("credit_ledger_entry_type")
}

model Session {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  stateVersion   Int       @default(1) @map("state_version")
  phase          String    @default("intake")
  // Canonical product contract: full base-session CVState snapshot.
  cvState        Json      @map("cv_state")
  // Operational contract: agent workflow state, not canonical resume truth.
  agentState     Json      @default("{}") @map("agent_state")
  // Operational contract: durable artifact metadata only.
  generatedOutput Json     @default("{}") @map("generated_output")
  // Operational contract: latest structured ATS analysis output.
  atsScore       Json?     @map("ats_score")
  creditsUsed    Int       @default(0) @map("credits_used")
  messageCount   Int       @default(0) @map("message_count")
  creditConsumed Boolean   @default(false) @map("credit_consumed")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  messages       Message[]
  cvVersions     CVVersion[]
  resumeTargets  ResumeTarget[]
  jobs           Job[]
  resumeGenerations ResumeGeneration[]
  creditReservations CreditReservation[]
  creditLedgerEntries CreditLedgerEntry[]

  @@index([userId])
  @@map("sessions")
}

model CVVersion {
  id             String       @id @default(cuid())
  sessionId      String       @map("session_id")
  targetResumeId String?      @map("target_resume_id")
  // Canonical product contract: immutable CVState history snapshot.
  snapshot       Json
  source         CVVersionSource
  createdAt      DateTime     @default(now()) @map("created_at")

  session        Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  targetResume   ResumeTarget? @relation(fields: [targetResumeId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([targetResumeId])
  @@map("cv_versions")
}

model ResumeTarget {
  id                   String      @id @default(cuid())
  sessionId            String      @map("session_id")
  targetJobDescription String      @map("target_job_description")
  // Canonical product contract: full target-derived CVState snapshot.
  derivedCvState       Json        @map("derived_cv_state")
  // Operational contract: structured targeting analysis.
  gapAnalysis          Json?       @map("gap_analysis")
  // Operational contract: durable target artifact metadata.
  generatedOutput      Json?       @map("generated_output")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  session              Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  cvVersions           CVVersion[]
  jobs                 Job[]
  resumeGenerations    ResumeGeneration[]
  creditReservations   CreditReservation[]
  creditLedgerEntries  CreditLedgerEntry[]

  @@index([sessionId, createdAt])
  @@map("resume_targets")
}

model JobApplication {
  id                 String               @id @default(cuid())
  userId             String               @map("user_id")
  role               String
  company            String
  status             JobApplicationStatus @default(aguardando)
  salary             String?
  location           String?
  // Operational contract: structured benefit list, still flexible.
  benefits           Json                 @default("[]")
  resumeVersionLabel String               @map("resume_version_label")
  jobDescription     String?              @map("job_description")
  notes              String?
  appliedAt          DateTime             @default(now()) @map("applied_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, appliedAt])
  @@index([userId, status, appliedAt])
  @@map("job_applications")
}

model Message {
  id         String   @id @default(cuid())
  sessionId  String   @map("session_id")
  role       String   // "user" | "assistant"
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("messages")
}

model Job {
  id                String      @id @default(dbgenerated("gen_random_uuid()::text"))
  userId            String      @map("user_id")
  sessionId         String?     @map("session_id")
  resumeTargetId    String?     @map("resume_target_id")
  idempotencyKey    String      @map("idempotency_key")
  type              String
  status            String      @default("queued")
  stage             String?
  progress          Json?
  dispatchInputRef  Json        @map("dispatch_input_ref")
  terminalResultRef Json?       @map("terminal_result_ref")
  terminalErrorRef  Json?       @map("terminal_error_ref")
  metadata          Json?
  claimedAt         DateTime?   @map("claimed_at")
  startedAt         DateTime?   @map("started_at")
  completedAt       DateTime?   @map("completed_at")
  cancelledAt       DateTime?   @map("cancelled_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session           Session?    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  resumeTarget      ResumeTarget? @relation(fields: [resumeTargetId], references: [id], onDelete: SetNull)
  creditReservations CreditReservation[]
  creditLedgerEntries CreditLedgerEntry[]

  @@unique([userId, type, idempotencyKey])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([type, status])
  @@index([sessionId, createdAt(sort: Desc)])
  @@index([resumeTargetId, createdAt(sort: Desc)])
  @@map("jobs")
}

model UserQuota {
  id                  String    @id @default(cuid())
  userId              String    @unique @map("user_id")
  plan                String    @default("free")  // Metadata only: "free" | "monthly" | "pro"
  creditsRemaining    Int       @default(0) @map("credits_remaining") // Legacy compatibility only; runtime credits live in credit_accounts
  asaasCustomerId     String?   @map("asaas_customer_id")
  asaasSubscriptionId String?   @map("asaas_subscription_id")
  renewsAt            DateTime? @map("renews_at")
  status              String    @default("active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user                User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([asaasCustomerId])
  @@index([asaasSubscriptionId])
  @@map("user_quotas")
}

model BillingCheckout {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  checkoutReference   String   @unique @map("checkout_reference")
  plan                String
  amountMinor         Int      @map("amount_minor")
  currency            String   @default("BRL")
  status              String   @default("pending")
  asaasLink           String?  @map("asaas_link")
  asaasPaymentId      String?  @map("asaas_payment_id")
  asaasSubscriptionId String?  @map("asaas_subscription_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user                User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([userId, status])
  @@index([asaasPaymentId])
  @@index([asaasSubscriptionId])
  @@map("billing_checkouts")
}

model ProcessedEvent {
  id               String   @id @default(cuid())
  eventId          String   @map("event_id")
  eventFingerprint String   @unique @map("event_fingerprint")
  eventType        String   @map("event_type")
  // Opaque event payload: audit/replay support, not stable product state.
  eventPayload     Json?    @map("event_payload")
  processedAt      DateTime @default(now()) @map("processed_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([eventId, eventType])
  @@index([createdAt])
  @@map("processed_events")
}

model ApiUsage {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  sessionId    String?  @map("session_id")
  model        String
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  totalTokens  Int      @map("total_tokens")
  costCents    Int      @map("cost_cents") // Cost in cents (USD) for easy integer math
  endpoint     String   // "agent" | "rewriter" | "ocr"
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([createdAt])
  @@map("api_usage")
}

model User {
  id             String             @id
  status         String             @default("active")
  displayName    String?            @map("display_name")
  primaryEmail   String?            @map("primary_email")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  authIdentities UserAuthIdentity[]
  creditAccount  CreditAccount?
  sessions       Session[]
  quota          UserQuota?
  apiUsage       ApiUsage[]
  billingCheckouts BillingCheckout[]
  jobApplications JobApplication[]
  billingInfo    CustomerBillingInfo?
  profile        UserProfile?
  jobs           Job[]
  pdfImportJobs  PdfImportJob[]
  linkedInImportJobs LinkedInImportJob[]
  resumeGenerations ResumeGeneration[]
  creditConsumptions CreditConsumption[]
  creditReservations CreditReservation[]
  creditLedgerEntries CreditLedgerEntry[]

  @@map("users")
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  // Canonical product contract: imported or manually edited profile CVState.
  cvState     Json     @map("cv_state")
  source      String   // 'linkedin' | 'pdf'
  linkedinUrl String?  @map("linkedin_url")
  profilePhotoUrl String? @map("profile_photo_url")
  extractedAt DateTime @map("extracted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_profiles")
}

model PdfImportJob {
  id                    String    @id @default(dbgenerated("gen_random_uuid()::text"))
  userId                String    @map("user_id")
  storagePath           String    @map("storage_path")
  sourceFileName        String    @map("source_file_name")
  sourceFileSize        Int       @map("source_file_size")
  replaceLinkedinImport Boolean   @default(false) @map("replace_linkedin_import")
  status                String    @default("pending")
  errorMessage          String?   @map("error_message")
  warningMessage        String?   @map("warning_message")
  claimedAt             DateTime? @map("claimed_at")
  completedAt           DateTime? @map("completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("pdf_import_jobs")
}

model LinkedInImportJob {
  id           String    @id @default(dbgenerated("gen_random_uuid()::text"))
  userId       String    @map("user_id")
  linkedinUrl  String    @map("linkedin_url")
  status       String    @default("pending") // 'pending' | 'processing' | 'completed' | 'failed'
  errorMessage String?   @map("error_message")
  claimedAt    DateTime? @map("claimed_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("linkedin_import_jobs")
}

model UserAuthIdentity {
  id              String    @id
  userId          String    @map("user_id")
  provider        String
  providerSubject String    @map("provider_subject")
  email           String?
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("user_auth_identities")
}

model CreditAccount {
  id               String   @id
  userId           String   @unique @map("user_id")
  creditsRemaining Int      @default(0) @map("credits_remaining") // Authoritative credit balance for all runtime checks and mutations
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_accounts")
}

model CustomerBillingInfo {
  id            String    @id @default(cuid())
  userId        String    @unique @map("user_id")
  cpfCnpj       String    @map("cpf_cnpj")
  phoneNumber   String    @map("phone_number")
  address       String
  addressNumber String    @map("address_number")
  postalCode    String    @map("postal_code")
  province      String
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("customer_billing_info")
}

model ResumeGeneration {
  id               String               @id @default(cuid())
  userId           String               @map("user_id")
  sessionId        String?              @map("session_id")
  resumeTargetId   String?              @map("resume_target_id")
  type             ResumeGenerationType
  status           String               @default("pending")
  idempotencyKey   String?              @unique @map("idempotency_key")
  // Canonical product contract: immutable source CVState snapshot.
  sourceCvSnapshot Json                 @map("source_cv_snapshot")
  // Canonical product contract: immutable generated CVState snapshot when present.
  generatedCvState Json?                @map("generated_cv_state")
  outputPdfPath    String?              @map("output_pdf_path")
  outputDocxPath   String?              @map("output_docx_path")
  failureReason    String?              @map("failure_reason")
  versionNumber    Int                  @default(1) @map("version_number")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  session          Session?             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  resumeTarget     ResumeTarget?        @relation(fields: [resumeTargetId], references: [id], onDelete: SetNull)
  creditConsumptions CreditConsumption[]
  creditReservations CreditReservation[]
  creditLedgerEntries CreditLedgerEntry[]

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([resumeTargetId, createdAt])
  @@map("resume_generations")
}

model CreditConsumption {
  id                 String               @id @default(cuid())
  userId             String               @map("user_id")
  resumeGenerationId String               @unique @map("resume_generation_id")
  type               ResumeGenerationType
  creditsUsed        Int                  @default(1) @map("credits_used")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeGeneration   ResumeGeneration     @relation(fields: [resumeGenerationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_consumptions")
}

model CreditReservation {
  id                   String                                  @id @default(dbgenerated("gen_random_uuid()::text"))
  userId               String                                  @map("user_id")
  generationIntentKey  String                                  @unique @map("generation_intent_key")
  jobId                String?                                 @map("job_id")
  sessionId            String?                                 @map("session_id")
  resumeTargetId       String?                                 @map("resume_target_id")
  resumeGenerationId   String?                                 @map("resume_generation_id")
  type                 ResumeGenerationType
  status               CreditReservationStatus                 @default(reserved)
  creditsReserved      Int                                     @default(1) @map("credits_reserved")
  failureReason        String?                                 @map("failure_reason")
  reservedAt           DateTime                                @default(now()) @map("reserved_at")
  finalizedAt          DateTime?                               @map("finalized_at")
  releasedAt           DateTime?                               @map("released_at")
  reconciliationStatus CreditReservationReconciliationStatus   @default(clean) @map("reconciliation_status")
  metadata             Json?
  createdAt            DateTime                                @default(now()) @map("created_at")
  updatedAt            DateTime                                @updatedAt @map("updated_at")

  user                 User                                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  job                  Job?                                    @relation(fields: [jobId], references: [id], onDelete: SetNull)
  session              Session?                                @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  resumeTarget         ResumeTarget?                           @relation(fields: [resumeTargetId], references: [id], onDelete: SetNull)
  resumeGeneration     ResumeGeneration?                       @relation(fields: [resumeGenerationId], references: [id], onDelete: SetNull)
  ledgerEntries        CreditLedgerEntry[]

  @@index([userId, createdAt])
  @@index([jobId])
  @@index([sessionId])
  @@index([resumeTargetId])
  @@index([resumeGenerationId])
  @@map("credit_reservations")
}

model CreditLedgerEntry {
  id                  String                @id @default(dbgenerated("gen_random_uuid()::text"))
  userId              String                @map("user_id")
  reservationId       String?               @map("reservation_id")
  generationIntentKey String                @map("generation_intent_key")
  entryType           CreditLedgerEntryType @map("entry_type")
  creditsDelta        Int                   @map("credits_delta")
  balanceAfter        Int?                  @map("balance_after")
  jobId               String?               @map("job_id")
  sessionId           String?               @map("session_id")
  resumeTargetId      String?               @map("resume_target_id")
  resumeGenerationId  String?               @map("resume_generation_id")
  metadata            Json?
  createdAt           DateTime              @default(now()) @map("created_at")

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservation         CreditReservation?    @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  job                 Job?                  @relation(fields: [jobId], references: [id], onDelete: SetNull)
  session             Session?              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  resumeTarget        ResumeTarget?         @relation(fields: [resumeTargetId], references: [id], onDelete: SetNull)
  resumeGeneration    ResumeGeneration?     @relation(fields: [resumeGenerationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([reservationId])
  @@index([generationIntentKey, createdAt])
  @@index([jobId])
  @@index([sessionId])
  @@index([resumeTargetId])
  @@index([resumeGenerationId])
  @@map("credit_ledger_entries")
}
